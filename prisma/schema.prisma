generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model KnowledgeNode {
  id          String   @id @default(cuid())
  content     String
  type        String   @default("concept") // concept, entity, decision, pattern, chat, fact
  source      String   @default("manual")  // manual, chat, upload, inference
  confidence  Float    @default(0.5)
  novelty     Float    @default(1.0)
  urgency     Float    @default(0.5)
  valence     Float    @default(0.0)  // -1 (negative) to 1 (positive) for visualization color
  arousal     Float    @default(0.5)  // 0 (calm) to 1 (excited) for visualization pulse
  decayRate   Float    @default(0.01) // how fast confidence decays when unused
  accessCount Int      @default(0)
  verified    Boolean  @default(false)
  promoted    Boolean  @default(false) // promoted to semantic store
  metadata    String   @default("{}") // JSON string for extra data
  tags        String   @default("[]") // JSON array of tag strings
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  edgesSource KnowledgeEdge[] @relation("SourceNode")
  edgesTarget KnowledgeEdge[] @relation("TargetNode")
  logs        SystemLog[]

  @@index([type])
  @@index([confidence])
  @@index([verified])
  @@index([createdAt])
}

model KnowledgeEdge {
  id           String         @id @default(cuid())
  sourceId     String
  targetId     String
  relationType String         @default("related") // related, causality, hierarchy, sequence, opposition
  weight       Float          @default(0.5)
  verified     Boolean        @default(false)
  metadata     String         @default("{}")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  source       KnowledgeNode  @relation("SourceNode", fields: [sourceId], references: [id])
  target       KnowledgeNode  @relation("TargetNode", fields: [targetId], references: [id])

  @@index([sourceId])
  @@index([targetId])
  @@index([relationType])
}

model SystemLog {
  id        String   @id @default(cuid())
  eventType String   // ingest, verify, decay, consolidate, policy_update, state_shift, error
  category  String   @default("system") // system, agent, memory, policy, graph
  level     String   @default("info")   // debug, info, warn, error
  payload   String   // JSON string
  nodeId    String?
  agentName String?

  createdAt DateTime @default(now())

  node      KnowledgeNode? @relation(fields: [nodeId], references: [id])

  @@index([eventType])
  @@index([category])
  @@index([level])
  @@index([createdAt])
}

model PolicyConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   // JSON string for flexible types
  valueType String   @default("number") // number, boolean, string, object
  category  String   @default("routing") // routing, retry, attention, decay, threshold
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([category])
  @@index([key])
}

model ChatMessage {
  id        String   @id @default(cuid())
  role      String   // user, assistant, system
  content   String
  processed Boolean  @default(false)
  nodeId    String?  // linked knowledge node if created
  metadata  String   @default("{}")
  createdAt DateTime @default(now())

  @@index([role])
  @@index([processed])
  @@index([createdAt])
}

model IngestQueue {
  id        String   @id @default(cuid())
  payload   String   // JSON string
  status    String   @default("pending") // pending, processing, completed, failed
  priority  Int      @default(5) // 1=low, 5=medium, 10=high
  attempts  Int      @default(0)
  maxAttempts Int    @default(3)
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  completedAt DateTime?

  @@index([status])
  @@index([priority])
}

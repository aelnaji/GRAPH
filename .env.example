# ============================================================
# GRAPH — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# --- Database ---
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/graph_db"

# --- AI / LLM Providers ---
# OpenAI or OpenAI-compatible API key
OPENAI_API_KEY="sk-..."

# Optional: Custom OpenAI-compatible base URL (e.g. OpenRouter, NVIDIA NIM, Ollama)
# OPENAI_BASE_URL="https://openrouter.ai/api/v1"
# OPENAI_BASE_URL="https://integrate.api.nvidia.com/v1"
# OPENAI_BASE_URL="http://localhost:11434/v1"

# Default model to use for chat/ingest agents
OPENAI_MODEL="gpt-4o"

# --- Authentication ---
# Secret key for signing JWT tokens (min 32 chars, use a random string)
JWT_SECRET="change-this-to-a-long-random-secret-string"

# API key to protect internal API endpoints (Bearer token)
API_SECRET_KEY="your-internal-api-secret"

# --- App Config ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# --- Optional: Caddy / Reverse Proxy ---
# DOMAIN="yourdomain.com"
